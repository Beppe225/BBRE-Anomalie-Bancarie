      <w:r>
        <w:t>- Ottimizzato B/N: nessuno sfondo colorato, solo testo e bordi</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="64D7C57E" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">

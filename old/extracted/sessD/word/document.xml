        <w:t xml:space="preserve">legale ai sensi della L. 247/2012. I dati e i calcoli si basano </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3A983D52" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">
      <w:r>
        <w:t xml:space="preserve">sulle informazioni fornite dal richiedente. Per l'avvio di </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7D7535C6" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">
      <w:r>
        <w:t xml:space="preserve">qualsiasi procedimento giudiziario o stragiudiziale è </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="149CD59C" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">
      <w:r>
        <w:t xml:space="preserve">indispensabile una perizia formale redatta da un Consulente </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5FBB6BB4" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">
      <w:r>
        <w:t xml:space="preserve">Tecnico abilitato e l'assistenza di un legale specializzato. </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="341FD4C6" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">
      <w:r>
        <w:t xml:space="preserve">BBRE Group declina ogni responsabilità per decisioni assunte </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4432777C" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF">
      <w:r>
        <w:t>sulla base esclusiva di questo documento."</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="5F1EBBCB" w14:textId="77777777" w:rsidR="000C0DEF" w:rsidRDefault="000C0DEF" w:rsidP="000C0DEF"/>

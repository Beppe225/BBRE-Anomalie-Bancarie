{
  "name": "bbre-anomalie-bancarie",
  "version": "1.0.1",
  "description": "BBRE - Analisi Anomalie Bancarie e Usura",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "node --test src/engine/__tests__/*.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "electron-updater": "^6.1.7",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bbre.anomalie",
    "productName": "BBRE Anomalie Bancarie",
    "executableName": "bbre-anomalie",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "data/**/*"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BBRE Anomalie Bancarie"
    },
    "mac": {
      "target": "dmg"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Beppe225",
      "repo": "BBRE-Anomalie-Bancarie",
      "private": false,
      "releaseType": "release"
    }
  },
  "keywords": [
    "bbre",
    "usura",
    "teg",
    "banche",
    "anomalie"
  ],
  "author": "BBRE Team",
  "license": "ISC"
}